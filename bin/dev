#!/usr/bin/env bash
set -euo pipefail

ROOT="${DEVCONTAINER_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
ENV_FILE="$ROOT/.env"
ENV_EXAMPLE="$ROOT/.env.example"
COMPOSE="$ROOT/compose.yaml"
NAME="${DEV_CONTAINER_NAME:-dev-fedora}"

if [[ ! -f "$ENV_FILE" && -f "$ENV_EXAMPLE" ]]; then
  cp "$ENV_EXAMPLE" "$ENV_FILE"
fi

if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

DEV_USER="${DEV_USER:-$(id -un)}"
DEV_UID="${DEV_UID:-$(id -u)}"
DEV_GID="${DEV_GID:-$(id -g)}"
FEDORA_VERSION="${FEDORA_VERSION:-44}"
CODEX_NPM_VERSION="${CODEX_NPM_VERSION:-0.141.0}"
HOST_HOME="${HOST_HOME:-$HOME}"
DEVCONTAINER_ROOT="${DEVCONTAINER_ROOT:-$ROOT}"
WORKSPACE_DIR="${WORKSPACE_DIR:-$HOST_HOME/workspace}"
HOST_CODEX_DIR="${HOST_CODEX_DIR:-$HOST_HOME/.codex}"
HOST_SSH_KEY="${HOST_SSH_KEY:-$HOST_HOME/.ssh/id_ed25519}"
HOST_AUTHORIZED_KEYS="${HOST_AUTHORIZED_KEYS:-$HOST_HOME/.ssh/authorized_keys}"
HOST_LLM_DIR="${HOST_LLM_DIR:-$HOST_HOME/llm}"

export DEV_USER DEV_UID DEV_GID FEDORA_VERSION CODEX_NPM_VERSION
export HOST_HOME DEVCONTAINER_ROOT WORKSPACE_DIR HOST_CODEX_DIR HOST_SSH_KEY HOST_AUTHORIZED_KEYS HOST_LLM_DIR

if [[ -S /var/run/docker.sock && ! -w /var/run/docker.sock && " $(id -nG) " != *" docker "* ]]; then
  if command -v sg >/dev/null 2>&1; then
    quoted=""
    for arg in "$0" "$@"; do
      printf -v part "%q" "$arg"
      quoted+=" $part"
    done
    exec sg docker -c "$quoted"
  fi
fi

compose() {
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE" "$@"
}

require_running() {
  if ! docker container inspect -f '{{.State.Running}}' "$NAME" >/dev/null 2>&1; then
    echo "$NAME is not running. Start it with: dev up" >&2
    exit 1
  fi
}

docker_exec_flags() {
  if [[ -t 0 && -t 1 ]]; then
    printf '%s\n' "-it"
  else
    printf '%s\n' "-i"
  fi
}

image_name() {
  printf 'local/dev-fedora:%s\n' "$FEDORA_VERSION"
}

ensure_authorized_key() {
  local auth_dir pub_type pub_body

  auth_dir="$(dirname "$HOST_AUTHORIZED_KEYS")"
  mkdir -p "$auth_dir"
  touch "$HOST_AUTHORIZED_KEYS"
  chmod 700 "$auth_dir"
  chmod 600 "$HOST_AUTHORIZED_KEYS"

  pub_type="$(awk 'NR == 1 { print $1 }' "$HOST_SSH_KEY.pub")"
  pub_body="$(awk 'NR == 1 { print $2 }' "$HOST_SSH_KEY.pub")"

  if ! awk -v type="$pub_type" -v body="$pub_body" \
    '$1 == type && $2 == body { found = 1 } END { exit(found ? 0 : 1) }' \
    "$HOST_AUTHORIZED_KEYS"; then
    if [[ -s "$HOST_AUTHORIZED_KEYS" && -n "$(tail -c 1 "$HOST_AUTHORIZED_KEYS")" ]]; then
      printf '\n' >> "$HOST_AUTHORIZED_KEYS"
    fi
    sed -n '1p' "$HOST_SSH_KEY.pub" >> "$HOST_AUTHORIZED_KEYS"
  fi
}

preflight() {
  mkdir -p \
    "$WORKSPACE_DIR" \
    "$HOST_CODEX_DIR" \
    "$HOST_LLM_DIR" \
    "$ROOT/shared/bin" \
    "$ROOT/shared/ssh" \
    "$ROOT/shared/ssh/host_keys" \
    "$ROOT/cache/npm" \
    "$ROOT/cache/pip" \
    "$ROOT/cache/cargo-registry" \
    "$ROOT/cache/cargo-git" \
    "$ROOT/cache/ssh"

  if [[ ! -f "$HOST_SSH_KEY.pub" ]]; then
    echo "missing $HOST_SSH_KEY.pub" >&2
    exit 1
  fi
  ensure_authorized_key

  if [[ ! -f "$ROOT/shared/ssh/host_keys/ssh_host_ed25519_key" ]]; then
    ssh-keygen -q -t ed25519 -N '' -f "$ROOT/shared/ssh/host_keys/ssh_host_ed25519_key"
  fi
  if [[ ! -f "$ROOT/shared/ssh/host_keys/ssh_host_ecdsa_key" ]]; then
    ssh-keygen -q -t ecdsa -b 521 -N '' -f "$ROOT/shared/ssh/host_keys/ssh_host_ecdsa_key"
  fi
  if [[ ! -f "$ROOT/shared/ssh/host_keys/ssh_host_rsa_key" ]]; then
    ssh-keygen -q -t rsa -b 4096 -N '' -f "$ROOT/shared/ssh/host_keys/ssh_host_rsa_key"
  fi
  chmod 600 "$ROOT/shared/ssh/host_keys"/ssh_host_*_key
  chmod 644 "$ROOT/shared/ssh/host_keys"/ssh_host_*_key.pub

  if [[ ! -s "$ROOT/shared/ssh/container-password" ]]; then
    umask 077
    openssl rand -base64 18 > "$ROOT/shared/ssh/container-password"
  fi
  chmod 600 "$ROOT/shared/ssh/container-password"

  if [[ -f "$HOST_HOME/.ssh/known_hosts" && ! -s "$ROOT/cache/ssh/known_hosts" ]]; then
    cp "$HOST_HOME/.ssh/known_hosts" "$ROOT/cache/ssh/known_hosts"
  else
    touch "$ROOT/cache/ssh/known_hosts"
  fi
  chmod 644 "$ROOT/cache/ssh/known_hosts"

  if [[ -f "$HOST_HOME/.gitconfig" ]]; then
    cp "$HOST_HOME/.gitconfig" "$ROOT/shared/gitconfig"
  else
    : > "$ROOT/shared/gitconfig"
  fi
  chmod 644 "$ROOT/shared/gitconfig"
}

case "${1:-help}" in
  up)
    preflight
    compose up -d --build
    ;;
  shell)
    require_running
    docker exec -it --user "$DEV_USER" --workdir /workspace "$NAME" bash
    ;;
  root)
    require_running
    docker exec -it --workdir /workspace "$NAME" bash
    ;;
  exec)
    require_running
    shift
    if [[ "$#" -eq 0 ]]; then
      echo "Usage: dev exec <command> [args...]" >&2
      exit 2
    fi
    docker exec "$(docker_exec_flags)" --user "$DEV_USER" --workdir /workspace "$NAME" "$@"
    ;;
  ssh)
    ssh -p 2222 "$DEV_USER@localhost"
    ;;
  stop)
    compose stop
    ;;
  restart)
    compose restart
    ;;
  rebuild)
    preflight
    compose build --no-cache
    compose up -d
    ;;
  recreate)
    preflight
    compose up -d --force-recreate
    ;;
  logs)
    if [[ "${2:-}" == "" ]]; then
      compose logs -f
    else
      compose logs -f "$2"
    fi
    ;;
  down)
    compose down
    ;;
  clean)
    compose down --remove-orphans
    ;;
  ps)
    compose ps
    ;;
  status)
    docker ps --filter "name=^/${NAME}$" --format "table {{.Names}}\t{{.Status}}\t{{.Image}}\t{{.Ports}}"
    ;;
  image)
    docker image ls "$(image_name)"
    ;;
  config)
    compose config
    ;;
  doctor)
    preflight
    echo "docker: $(docker version --format '{{.Server.Version}}')"
    echo "compose: $(docker compose version --short)"
    echo "image: $(image_name)"
    if docker container inspect "$NAME" >/dev/null 2>&1; then
      docker ps -a --filter "name=^/${NAME}$" --format "container: {{.Names}} {{.Status}}"
    else
      echo "container: missing"
    fi
    ;;
  gui-image)
    docker image ls "local/dev-fedora-gui:$FEDORA_VERSION"
    ;;
  password)
    preflight
    cat "$ROOT/shared/ssh/container-password"
    ;;
  *)
    cat <<'EOF'
Usage: dev <command>

Commands:
  up         build and start dev-fedora
  shell      open a shell as the configured dev user
  root       open a root shell
  exec       run a command as the configured dev user in /workspace
  ssh        ssh to localhost:2222
  stop       stop the container
  restart    restart the container
  recreate   recreate the container without rebuilding
  rebuild    rebuild from scratch and start
  logs       follow compose logs
  down       remove the container, keep workspace/cache/shared
  clean      down plus remove compose orphans, keep workspace/cache/shared
  ps         show compose status
  status     show docker status
  image      show the base dev image
  gui-image  show the optional GUI dev image
  config     render compose config
  doctor     check Docker, paths, image, and container state
  password   print the generated container SSH password
EOF
    ;;
esac
